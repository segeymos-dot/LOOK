# Supabase (оставьте пустым для демо-режима с mock-данными)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — только для сервера (создание тестовых пользователей)
# Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Database URI — для npm run supabase:apply-migration / supabase:seed-test-users
# Project Settings → Database → Connection string (URI)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Принудительно включить/выключить demo-режим (опционально)
# NEXT_PUBLIC_USE_MOCK_DATA=true

# Локальный URL приложения (редиректы в dev; на prod — ваш домен)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Тестовый вход (в dev включён по умолчанию)
# NEXT_PUBLIC_ENABLE_TEST_LOGIN=true
# NEXT_PUBLIC_TEST_CUSTOMER_EMAIL=customer@test.look
# NEXT_PUBLIC_TEST_CUSTOMER_PASSWORD=Test1234!
# NEXT_PUBLIC_TEST_PROVIDER_EMAIL=provider@test.look
# NEXT_PUBLIC_TEST_PROVIDER_PASSWORD=Test1234!

# Комиссия платформы LOOK (0.15 = 15%)
# NEXT_PUBLIC_PLATFORM_COMMISSION_RATE=0.15
