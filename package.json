{
  "name": "look",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "lsof -ti:3000 | xargs kill -9 2>/dev/null; rm -rf .next && next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "supabase:gen-types": "supabase gen types typescript --local > src/types/database.types.ts",
    "supabase:apply-migration": "node scripts/apply-migration.mjs",
    "supabase:seed-test-users": "node scripts/seed-test-users.mjs",
    "test:roles": "node scripts/test-roles.mjs",
    "test:both-role-offer": "node scripts/test-both-role-offer.mjs",
    "test:migration-010": "node scripts/verify-migration-010.mjs",
    "test:migration-010:seed": "node scripts/verify-migration-010.mjs --seed-provider",
    "test:finance": "node scripts/verify-financial-cycle.mjs",
    "test:migration-012": "node scripts/verify-migration-012.mjs",
    "test:order-flow": "node scripts/verify-order-flow.mjs",
    "test:registration": "node scripts/verify-registration.mjs",
    "test:audit-migrations": "node scripts/audit-migrations.mjs",
    "test:cancel-request": "node scripts/verify-cancel-request.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.8",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "pg": "^8.21.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
